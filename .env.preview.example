# FuelFlow preview environment template
# Replace all placeholder values before using.

# Frontend
VITE_SUPABASE_URL=https://your-preview-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-preview-anon-key
VITE_GOOGLE_CLIENT_ID=your-preview-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_AUTH_PROXY=https://your-preview-auth-proxy.example.com

# Serverless API
NEXT_PUBLIC_SUPABASE_URL=https://your-preview-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-preview-service-role-key

# Optional runtime restrictions
# Comma-separated list of allowed browser origins for preview access.
ALLOWED_ORIGINS=https://your-preview-app.vercel.app,http://localhost:5173
