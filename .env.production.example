# FuelFlow production environment template
# Replace all placeholder values before using.

# Frontend
VITE_SUPABASE_URL=https://your-production-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-production-anon-key
VITE_GOOGLE_CLIENT_ID=your-production-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_AUTH_PROXY=https://auth.your-domain.com

# Serverless API
NEXT_PUBLIC_SUPABASE_URL=https://your-production-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key

# Optional runtime restrictions
# Use your real production web origins only.
ALLOWED_ORIGINS=https://app.your-domain.com,https://www.app.your-domain.com
